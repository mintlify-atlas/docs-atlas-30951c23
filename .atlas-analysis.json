  "keyFeatures": [
    "Auto-discovery of var_cms_admin.py in every installed Django app",
    "Glassmorphic dark-mode UI with collapsible sidebar and HSL accent color customization",
    "Role-based and per-user fine-grained permissions (add, list, view, edit, delete)",
    "Field-level edit control per role via role_editable_fields",
    "Integrated Quill.js rich text (HTML) editor via html_fields",
    "Regex field validation (client-side + server-side) via regex_validators",
    "Built-in image cropper with rotate, flip, and custom aspect ratio",
    "Media format conversion: images (JPEG/PNG/WebP), audio (MP3/WAV), video (MP4/WebM)",
    "Modal-based media previews for images, video, audio, and PDFs",
    "Custom object actions on list and detail views",
    "12-column grid form layout system with width presets and field row grouping",
    "Custom dropdown widgets: select_search, multiselect, multiselect_search",
    "Optional email OTP two-factor authentication",
    "Forgot password and in-dashboard password reset flows",
    "Dashboard card visibility and custom card buttons",
    "Optional Tailwind CSS CLI integration"
  ],
